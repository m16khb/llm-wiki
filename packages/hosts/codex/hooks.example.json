{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "llm-wiki hook UserPromptSubmit --host codex --json",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "llm-wiki hook PostToolUse --host codex --json",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "llm-wiki hook Stop --host codex --json",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
