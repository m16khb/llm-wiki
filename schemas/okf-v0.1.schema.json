{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/m16khb/llm-wiki/schemas/okf-v0.1.schema.json",
  "title": "OKF v0.1 concept frontmatter",
  "type": "object",
  "required": ["type"],
  "additionalProperties": true,
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "resource": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
